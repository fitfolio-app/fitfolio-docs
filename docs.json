{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FitFolio Product Guide",
  "description": "Guia público do FitFolio para usuários, profissionais e pessoas que querem entender como usar treino, dieta, progresso e comunidade no app.",
  "colors": {
    "primary": "#FFFFFF",
    "light": "#F5F5F5",
    "dark": "#FAFAFA"
  },
  "fonts": {
    "family": "Geist"
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/assets/logo.png",
    "dark": "/assets/logo_invertido.png",
    "href": "https://fitfolio.com.br"
  },
  "favicon": "/assets/favicon.png",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "navbar": {
    "links": [
      {
        "label": "Site",
        "href": "https://fitfolio.com.br"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/fitfolio-app/fitfolio-docs",
        "icon": "github"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Baixar app",
      "href": "https://fitfolio.com.br/app"
    }
  },
  "footer": {
    "socials": {
      "website": "https://fitfolio.com.br",
      "github": "https://github.com/fitfolio-app/fitfolio-docs"
    },
    "links": [
      {
        "header": "Produto",
        "items": [
          {
            "label": "Site oficial",
            "href": "https://fitfolio.com.br"
          },
          {
            "label": "Baixar app",
            "href": "https://fitfolio.com.br/app"
          }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Buscar: Foco em uso do produto."
  },
  "navigation": {
    "groups": [
      {
        "group": "Comece aqui",
        "pages": [
          "index",
          "product-guide/getting-started",
          "product-guide/onboarding"
        ]
      },
      {
        "group": "Guia do produto",
        "pages": [
          "product-guide/training",
          "product-guide/nutrition",
          "product-guide/progress",
          "product-guide/community",
          "product-guide/premium"
        ]
      },
      {
        "group": "Profissionais",
        "pages": [
          "professionals/overview",
          "professionals/students",
          "professionals/programs"
        ]
      },
      {
        "group": "Ajuda",
        "pages": [
          "help/faq",
          "help/troubleshooting",
          "help/privacy-and-safety",
          "help/account-deletion"
        ]
      }
    ]
  }
}
